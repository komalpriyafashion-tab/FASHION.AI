<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FashionAI — Virtual Try-On Studio</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #080810;
    --surface: #10101e;
    --surface2: #16162a;
    --border: rgba(255,255,255,0.07);
    --accent: #c9a96e;
    --accent2: #e8c99a;
    --pink: #e07070;
    --blue: #6eb5c9;
    --text: #f0ede8;
    --muted: #7a7890;
    --radius: 16px;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ── ANIMATED BACKGROUND ── */
  .bg-orbs {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
    overflow: hidden;
  }
  .orb {
    position: absolute; border-radius: 50%;
    filter: blur(80px); opacity: 0.18; animation: drift 18s ease-in-out infinite;
  }
  .orb1 { width:500px; height:500px; background:#c9a96e; top:-100px; left:-100px; animation-delay:0s; }
  .orb2 { width:400px; height:400px; background:#6eb5c9; bottom:-50px; right:-80px; animation-delay:-6s; }
  .orb3 { width:300px; height:300px; background:#e07070; top:50%; left:50%; animation-delay:-12s; }
  @keyframes drift {
    0%,100% { transform: translate(0,0) scale(1); }
    33% { transform: translate(40px,-30px) scale(1.1); }
    66% { transform: translate(-30px,40px) scale(0.95); }
  }

  /* ── LOGIN SCREEN ── */
  #loginScreen {
    position: fixed; inset: 0; z-index: 1000;
    background: var(--bg);
    display: flex; align-items: center; justify-content: center;
  }
  .login-box {
    background: rgba(16,16,30,0.95);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 48px 40px;
    width: 420px;
    max-width: 95vw;
    backdrop-filter: blur(20px);
    box-shadow: 0 40px 80px rgba(0,0,0,0.6);
    position: relative; z-index: 1;
    animation: slideUp 0.6s cubic-bezier(0.16,1,0.3,1);
  }
  @keyframes slideUp {
    from { opacity:0; transform:translateY(30px); }
    to { opacity:1; transform:translateY(0); }
  }
  .login-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem;
    font-weight: 300;
    letter-spacing: 2px;
    color: var(--accent);
    text-align: center;
    margin-bottom: 4px;
  }
  .login-sub { text-align:center; color:var(--muted); font-size:0.85rem; margin-bottom:32px; }
  .input-group { margin-bottom: 16px; }
  .input-group label { display:block; font-size:0.8rem; color:var(--muted); margin-bottom:6px; }
  .input-group input {
    width:100%; padding:12px 16px;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    border-radius: 10px; color: var(--text);
    font-family: 'DM Sans', sans-serif; font-size:0.9rem;
    outline:none; transition:border 0.2s;
  }
  .input-group input:focus { border-color: var(--accent); }
  .btn-login {
    width:100%; padding:14px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border:none; border-radius:12px;
    color: #1a1208; font-weight:600; font-size:1rem;
    cursor:pointer; margin-top:8px;
    transition:transform 0.2s, box-shadow 0.2s;
  }
  .btn-login:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(201,169,110,0.4); }
  .login-divider { text-align:center; color:var(--muted); font-size:0.8rem; margin:20px 0; }
  .social-btns { display:flex; gap:10px; }
  .btn-social {
    flex:1; padding:11px;
    background: rgba(255,255,255,0.05);
    border:1px solid var(--border); border-radius:10px;
    color:var(--text); font-size:0.85rem;
    cursor:pointer; transition:background 0.2s;
    display:flex; align-items:center; justify-content:center; gap:8px;
  }
  .btn-social:hover { background:rgba(255,255,255,0.1); }
  .signup-link { text-align:center; margin-top:20px; color:var(--muted); font-size:0.85rem; }
  .signup-link a { color:var(--accent); text-decoration:none; }

  /* ── MAIN APP ── */
  #mainApp { display:none; position:relative; z-index:1; }

  /* HEADER */
  header {
    display:flex; align-items:center; justify-content:space-between;
    padding:16px 28px;
    background: rgba(8,8,16,0.8);
    backdrop-filter: blur(20px);
    border-bottom:1px solid var(--border);
    position:sticky; top:0; z-index:100;
  }
  .logo {
    font-family:'Cormorant Garamond',serif;
    font-size:1.7rem; font-weight:300;
    letter-spacing:2px; color:var(--accent);
  }
  .logo span { color:var(--text); }
  .header-nav { display:flex; gap:6px; }
  .nav-btn {
    padding:8px 16px;
    background:transparent; border:1px solid var(--border);
    border-radius:8px; color:var(--muted);
    font-size:0.82rem; cursor:pointer;
    transition:all 0.2s;
  }
  .nav-btn.active, .nav-btn:hover {
    background:rgba(201,169,110,0.12);
    border-color:var(--accent); color:var(--accent);
  }
  .header-right { display:flex; align-items:center; gap:12px; }
  .credits-badge {
    padding:6px 14px;
    background:rgba(201,169,110,0.1);
    border:1px solid rgba(201,169,110,0.3);
    border-radius:20px; font-size:0.8rem; color:var(--accent2);
  }
  .avatar {
    width:34px; height:34px; border-radius:50%;
    background:linear-gradient(135deg,var(--accent),var(--pink));
    display:flex; align-items:center; justify-content:center;
    font-size:0.85rem; font-weight:600; color:#1a1208; cursor:pointer;
  }

  /* LAYOUT */
  .app-body {
    display:grid;
    grid-template-columns: 320px 1fr 300px;
    height: calc(100vh - 65px);
    overflow:hidden;
  }

  /* PANELS */
  .panel {
    background: var(--surface);
    border-right:1px solid var(--border);
    overflow-y:auto;
    padding:20px;
  }
  .panel:last-child { border-right:none; border-left:1px solid var(--border); }
  .panel::-webkit-scrollbar { width:4px; }
  .panel::-webkit-scrollbar-thumb { background:var(--border); border-radius:2px; }

  .section-title {
    font-family:'Cormorant Garamond',serif;
    font-size:0.75rem; letter-spacing:3px;
    text-transform:uppercase; color:var(--muted);
    margin-bottom:12px; padding-bottom:8px;
    border-bottom:1px solid var(--border);
  }

  /* UPLOAD ZONE */
  .upload-zone {
    border:2px dashed rgba(201,169,110,0.3);
    border-radius:var(--radius); padding:28px 16px;
    text-align:center; cursor:pointer;
    transition:all 0.3s; margin-bottom:16px;
    background: rgba(201,169,110,0.03);
    position:relative; overflow:hidden;
  }
  .upload-zone:hover {
    border-color:var(--accent);
    background:rgba(201,169,110,0.07);
  }
  .upload-zone input[type=file] {
    position:absolute; inset:0; opacity:0; cursor:pointer;
  }
  .upload-icon { font-size:2rem; margin-bottom:8px; }
  .upload-text { font-size:0.85rem; color:var(--muted); }
  .upload-text strong { color:var(--accent); display:block; font-size:0.95rem; }
  .preview-img {
    width:100%; border-radius:12px; margin-top:10px;
    display:none; max-height:180px; object-fit:cover;
  }

  /* PROMPT BOX */
  .prompt-box {
    width:100%; min-height:90px;
    background:rgba(255,255,255,0.04);
    border:1px solid var(--border); border-radius:12px;
    color:var(--text); padding:12px;
    font-family:'DM Sans',sans-serif; font-size:0.88rem;
    resize:vertical; outline:none;
    transition:border 0.2s; margin-bottom:8px;
  }
  .prompt-box:focus { border-color:var(--accent); }

  /* TAG SELECTOR */
  .tag-group { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:14px; }
  .tag {
    padding:5px 12px;
    background:rgba(255,255,255,0.05);
    border:1px solid var(--border); border-radius:20px;
    font-size:0.78rem; color:var(--muted); cursor:pointer;
    transition:all 0.2s;
  }
  .tag.active, .tag:hover {
    background:rgba(201,169,110,0.15);
    border-color:var(--accent); color:var(--accent2);
  }

  /* SLIDER */
  .slider-row { display:flex; align-items:center; gap:10px; margin-bottom:12px; }
  .slider-label { font-size:0.8rem; color:var(--muted); width:80px; flex-shrink:0; }
  .slider-val { font-size:0.8rem; color:var(--accent); width:30px; text-align:right; }
  input[type=range] {
    flex:1; -webkit-appearance:none; height:4px;
    background:rgba(255,255,255,0.1); border-radius:2px; outline:none;
  }
  input[type=range]::-webkit-slider-thumb {
    -webkit-appearance:none; width:14px; height:14px;
    background:var(--accent); border-radius:50%; cursor:pointer;
  }

  /* SELECT */
  .select-input {
    width:100%; padding:9px 12px;
    background:rgba(255,255,255,0.05);
    border:1px solid var(--border); border-radius:10px;
    color:var(--text); font-family:'DM Sans',sans-serif;
    font-size:0.85rem; outline:none; cursor:pointer;
    margin-bottom:12px;
  }

  /* MODELS GRID */
  .models-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-bottom:14px; }
  .model-card {
    border:2px solid var(--border); border-radius:10px;
    overflow:hidden; cursor:pointer; transition:border 0.2s;
    position:relative;
  }
  .model-card.active { border-color:var(--accent); }
  .model-avatar {
    width:100%; aspect-ratio:3/4;
    display:flex; align-items:center; justify-content:center;
    font-size:2rem;
    background:linear-gradient(160deg,rgba(201,169,110,0.1),rgba(110,181,201,0.1));
  }
  .model-name { text-align:center; font-size:0.72rem; padding:5px; color:var(--muted); }
  .model-card.active .model-name { color:var(--accent); }

  /* GENERATE BUTTON */
  .btn-generate {
    width:100%; padding:16px;
    background:linear-gradient(135deg,var(--accent) 0%,#e8b86e 50%,var(--accent2) 100%);
    border:none; border-radius:14px;
    color:#1a1208; font-weight:700; font-size:1rem;
    cursor:pointer; transition:all 0.3s;
    letter-spacing:0.5px;
    box-shadow: 0 4px 15px rgba(201,169,110,0.3);
    position:relative; overflow:hidden;
  }
  .btn-generate::after {
    content:''; position:absolute; inset:0;
    background:linear-gradient(135deg,transparent,rgba(255,255,255,0.15),transparent);
    transform:translateX(-100%);
    transition:transform 0.5s;
  }
  .btn-generate:hover::after { transform:translateX(100%); }
  .btn-generate:hover { transform:translateY(-2px); box-shadow:0 8px 25px rgba(201,169,110,0.5); }
  .btn-generate:disabled { opacity:0.6; cursor:not-allowed; transform:none; }

  /* API KEY SECTION */
  .api-section { margin-bottom:16px; }
  .api-input-wrap { display:flex; gap:6px; }
  .api-key-input {
    flex:1; padding:9px 12px;
    background:rgba(255,255,255,0.05);
    border:1px solid var(--border); border-radius:10px;
    color:var(--text); font-size:0.78rem; outline:none;
  }
  .btn-save-key {
    padding:9px 14px;
    background:rgba(201,169,110,0.2);
    border:1px solid var(--accent); border-radius:10px;
    color:var(--accent); font-size:0.78rem; cursor:pointer;
  }

  /* CENTER - CANVAS */
  .canvas-area {
    background: var(--surface2);
    display:flex; flex-direction:column;
    overflow:hidden;
  }
  .canvas-header {
    padding:14px 20px;
    border-bottom:1px solid var(--border);
    display:flex; align-items:center; justify-content:space-between;
  }
  .canvas-title { font-family:'Cormorant Garamond',serif; font-size:1.1rem; font-weight:400; }
  .canvas-actions { display:flex; gap:8px; }
  .btn-sm {
    padding:6px 12px;
    background:rgba(255,255,255,0.06);
    border:1px solid var(--border); border-radius:8px;
    color:var(--muted); font-size:0.78rem; cursor:pointer;
    transition:all 0.2s;
  }
  .btn-sm:hover { border-color:var(--accent); color:var(--accent); }

  .results-grid {
    flex:1; overflow-y:auto;
    padding:20px;
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
    gap:14px;
    align-content:start;
  }

  .empty-state {
    grid-column:1/-1;
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    height:400px; color:var(--muted);
    text-align:center;
  }
  .empty-icon { font-size:4rem; margin-bottom:16px; opacity:0.4; }
  .empty-title {
    font-family:'Cormorant Garamond',serif;
    font-size:1.5rem; font-weight:300; margin-bottom:8px; color:var(--text);
    opacity:0.5;
  }
  .empty-sub { font-size:0.85rem; opacity:0.5; }

  /* RESULT CARD */
  .result-card {
    border-radius:14px; overflow:hidden;
    border:1px solid var(--border);
    background:var(--surface);
    transition:transform 0.2s, box-shadow 0.2s;
    position:relative; group;
    animation: fadeInCard 0.4s ease both;
  }
  @keyframes fadeInCard {
    from { opacity:0; transform:scale(0.96) translateY(10px); }
    to { opacity:1; transform:scale(1) translateY(0); }
  }
  .result-card:hover { transform:translateY(-4px); box-shadow:0 12px 30px rgba(0,0,0,0.4); }
  .result-img {
    width:100%; aspect-ratio:3/4; object-fit:cover;
    display:block; background:linear-gradient(160deg,#1a1a2e,#16213e);
  }
  .result-img-placeholder {
    width:100%; aspect-ratio:3/4;
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    background:linear-gradient(160deg,#1a1a2e,#16213e);
    color:var(--muted); gap:8px; font-size:0.8rem;
  }
  .spin { animation:spin 1.5s linear infinite; display:inline-block; font-size:1.5rem; }
  @keyframes spin { to { transform:rotate(360deg); } }
  .result-meta { padding:10px 12px; }
  .result-label { font-size:0.8rem; color:var(--text); margin-bottom:4px; }
  .result-sub { font-size:0.72rem; color:var(--muted); }
  .result-actions {
    display:flex; gap:6px; padding:0 12px 12px;
  }
  .btn-action {
    flex:1; padding:7px;
    background:rgba(255,255,255,0.05);
    border:1px solid var(--border); border-radius:8px;
    color:var(--muted); font-size:0.75rem; cursor:pointer;
    transition:all 0.2s; text-align:center;
  }
  .btn-action:hover { background:rgba(201,169,110,0.12); color:var(--accent); border-color:var(--accent); }
  .btn-action.primary { background:rgba(201,169,110,0.15); color:var(--accent2); border-color:rgba(201,169,110,0.4); }

  /* RIGHT PANEL - ANALYSIS */
  .analysis-box {
    background:rgba(255,255,255,0.03);
    border:1px solid var(--border); border-radius:12px;
    padding:14px; margin-bottom:14px; min-height:100px;
    font-size:0.83rem; line-height:1.6; color:var(--text);
  }
  .analysis-box.loading { color:var(--muted); font-style:italic; }
  .badge { 
    display:inline-block; padding:3px 10px;
    background:rgba(201,169,110,0.15);
    border:1px solid rgba(201,169,110,0.3);
    border-radius:20px; font-size:0.72rem; color:var(--accent2);
    margin:3px 2px;
  }

  /* HISTORY */
  .history-item {
    display:flex; gap:10px; align-items:center;
    padding:10px; border-radius:10px; cursor:pointer;
    transition:background 0.2s; margin-bottom:6px;
    border:1px solid transparent;
  }
  .history-item:hover { background:rgba(255,255,255,0.04); border-color:var(--border); }
  .history-thumb {
    width:44px; height:56px; border-radius:8px;
    background:linear-gradient(160deg,#1a1a2e,#16213e);
    flex-shrink:0; display:flex; align-items:center; justify-content:center;
    font-size:1.2rem; overflow:hidden;
  }
  .history-thumb img { width:100%; height:100%; object-fit:cover; }
  .history-info { flex:1; overflow:hidden; }
  .history-prompt { font-size:0.78rem; color:var(--text); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .history-time { font-size:0.7rem; color:var(--muted); margin-top:3px; }

  /* NOTIFICATION */
  .toast {
    position:fixed; bottom:24px; right:24px;
    padding:12px 20px;
    background:rgba(22,22,42,0.95);
    border:1px solid var(--accent);
    border-radius:12px; color:var(--text);
    font-size:0.85rem; z-index:9999;
    backdrop-filter:blur(10px);
    transform:translateY(100px); opacity:0;
    transition:all 0.3s; pointer-events:none;
  }
  .toast.show { transform:translateY(0); opacity:1; }

  /* PROGRESS BAR */
  .progress-bar {
    height:3px; background:rgba(255,255,255,0.08);
    border-radius:2px; overflow:hidden; margin-bottom:12px;
  }
  .progress-fill {
    height:100%; background:linear-gradient(90deg,var(--accent),var(--accent2));
    border-radius:2px; width:0; transition:width 0.3s;
  }

  /* TABS */
  .tabs { display:flex; gap:4px; margin-bottom:16px; }
  .tab-btn {
    flex:1; padding:8px 6px;
    background:transparent; border:1px solid var(--border);
    border-radius:8px; color:var(--muted);
    font-size:0.78rem; cursor:pointer; transition:all 0.2s;
  }
  .tab-btn.active { background:rgba(201,169,110,0.12); border-color:var(--accent); color:var(--accent); }

  .tab-content { display:none; }
  .tab-content.active { display:block; }

  /* MOBILE RESPONSIVE */
  @media (max-width:900px) {
    .app-body { grid-template-columns:1fr; }
    .panel:first-child { display:none; }
    .panel:last-child { display:none; }
  }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width:4px; height:4px; }
  ::-webkit-scrollbar-track { background:transparent; }
  ::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.1); border-radius:2px; }
</style>
</head>
<body>

<!-- BG ORBS -->
<div class="bg-orbs">
  <div class="orb orb1"></div>
  <div class="orb orb2"></div>
  <div class="orb orb3"></div>
</div>

<!-- ═══ LOGIN SCREEN ═══ -->
<div id="loginScreen">
  <div class="bg-orbs"><div class="orb orb1"></div><div class="orb orb2"></div></div>
  <div class="login-box">
    <div class="login-logo">Fashion<span style="color:var(--text)">AI</span></div>
    <div class="login-sub">Virtual Try-On Studio — Powered by Claude</div>
    <div class="input-group">
      <label>Email Address</label>
      <input type="email" id="emailInput" placeholder="your@email.com" value="demo@fashionai.com">
    </div>
    <div class="input-group">
      <label>Password</label>
      <input type="password" id="passInput" placeholder="••••••••" value="demo123">
    </div>
    <button class="btn-login" onclick="doLogin()">✦ Enter Studio</button>
    <div class="login-divider">— or continue with —</div>
    <div class="social-btns">
      <button class="btn-social" onclick="doLogin()">🔵 Google</button>
      <button class="btn-social" onclick="doLogin()">⚫ GitHub</button>
    </div>
    <div class="signup-link">New user? <a href="#" onclick="doLogin()">Create free account →</a></div>
  </div>
</div>

<!-- ═══ MAIN APP ═══ -->
<div id="mainApp">

  <!-- HEADER -->
  <header>
    <div class="logo">Fashion<span>AI</span></div>
    <div class="header-nav">
      <button class="nav-btn active" onclick="switchView('tryon',this)">✦ Try-On</button>
      <button class="nav-btn" onclick="switchView('gallery',this)">Gallery</button>
      <button class="nav-btn" onclick="switchView('videoad',this)">Video Ad</button>
      <button class="nav-btn" onclick="switchView('settings',this)">Settings</button>
    </div>
    <div class="header-right">
      <div class="credits-badge" id="creditsDisplay">✦ 50 Credits</div>
      <div class="avatar" title="Profile">FA</div>
    </div>
  </header>

  <!-- ═══ TRY-ON VIEW ═══ -->
  <div class="app-body" id="view-tryon">

    <!-- LEFT PANEL -->
    <div class="panel">

      <!-- API KEYS -->
      <div class="section-title">⚙ API Keys</div>
      <div class="api-section">
        <div style="font-size:0.78rem;color:var(--muted);margin-bottom:6px;">Anthropic (Claude)</div>
        <div class="api-input-wrap">
          <input class="api-key-input" id="claudeKey" type="password" placeholder="sk-ant-...">
          <button class="btn-save-key" onclick="saveKey('claude')">Save</button>
        </div>
      </div>
      <div class="api-section">
        <div style="font-size:0.78rem;color:var(--muted);margin-bottom:6px;">Stability AI (Images)</div>
        <div class="api-input-wrap">
          <input class="api-key-input" id="stabilityKey" type="password" placeholder="sk-...">
          <button class="btn-save-key" onclick="saveKey('stability')">Save</button>
        </div>
      </div>

      <!-- PRODUCT UPLOAD -->
      <div class="section-title">📸 Product / Fabric Image</div>
      <div class="upload-zone" id="fabricZone">
        <input type="file" accept="image/*" onchange="handleFabricUpload(event)">
        <div class="upload-icon">🧵</div>
        <div class="upload-text"><strong>Upload Fabric / Product</strong>Ghagra, Kurti, Saree, Lehenga design</div>
        <img id="fabricPreview" class="preview-img">
      </div>

      <!-- SELECT MODEL -->
      <div class="section-title">👗 Select Model</div>
      <div class="models-grid">
        <div class="model-card active" onclick="selectModel(this,'Ananya')" data-model="Ananya">
          <div class="model-avatar">👩🏽</div>
          <div class="model-name">Ananya</div>
        </div>
        <div class="model-card" onclick="selectModel(this,'Priya')" data-model="Priya">
          <div class="model-avatar">👩🏻</div>
          <div class="model-name">Priya</div>
        </div>
        <div class="model-card" onclick="selectModel(this,'Meera')" data-model="Meera">
          <div class="model-avatar">👩🏾</div>
          <div class="model-name">Meera</div>
        </div>
        <div class="model-card" onclick="selectModel(this,'Kavya')" data-model="Kavya">
          <div class="model-avatar">🧕🏽</div>
          <div class="model-name">Kavya</div>
        </div>
        <div class="model-card" onclick="selectModel(this,'Riya')" data-model="Riya">
          <div class="model-avatar">👩🏻‍🦱</div>
          <div class="model-name">Riya</div>
        </div>
        <div class="model-card" onclick="selectModel(this,'Custom')" data-model="Custom">
          <div class="model-avatar" style="font-size:1.3rem">➕</div>
          <div class="model-name">Custom</div>
        </div>
      </div>

      <!-- OUTFIT TYPE -->
      <div class="section-title">👘 Outfit Type</div>
      <div class="tag-group" id="outfitTags">
        <div class="tag active" onclick="selectTag(this,'outfit')">Ghagra</div>
        <div class="tag" onclick="selectTag(this,'outfit')">Kurti</div>
        <div class="tag" onclick="selectTag(this,'outfit')">Lehenga</div>
        <div class="tag" onclick="selectTag(this,'outfit')">Saree</div>
        <div class="tag" onclick="selectTag(this,'outfit')">Anarkali</div>
        <div class="tag" onclick="selectTag(this,'outfit')">Sharara</div>
        <div class="tag" onclick="selectTag(this,'outfit')">Suit</div>
        <div class="tag" onclick="selectTag(this,'outfit')">Maxi Dress</div>
      </div>

      <!-- POSE -->
      <div class="section-title">🧍 Pose & Setting</div>
      <div class="tag-group">
        <div class="tag active" onclick="selectTag(this,'pose')">Studio</div>
        <div class="tag" onclick="selectTag(this,'pose')">Outdoor</div>
        <div class="tag" onclick="selectTag(this,'pose')">Walking</div>
        <div class="tag" onclick="selectTag(this,'pose')">Sitting</div>
        <div class="tag" onclick="selectTag(this,'pose')">Twirling</div>
        <div class="tag" onclick="selectTag(this,'pose')">Royal</div>
      </div>

      <!-- SETTINGS TABS -->
      <div class="tabs">
        <button class="tab-btn active" onclick="switchTab(this,'basic')">Basic</button>
        <button class="tab-btn" onclick="switchTab(this,'advanced')">Advanced</button>
      </div>

      <div class="tab-content active" id="tab-basic">
        <div class="section-title">🎨 Style</div>
        <div class="tag-group">
          <div class="tag active" onclick="selectTag(this,'style')">Photorealistic</div>
          <div class="tag" onclick="selectTag(this,'style')">Fashion Editorial</div>
          <div class="tag" onclick="selectTag(this,'style')">Magazine</div>
          <div class="tag" onclick="selectTag(this,'style')">Cinematic</div>
        </div>
        <div class="section-title">🔢 Variants</div>
        <div class="slider-row">
          <div class="slider-label">Count</div>
          <input type="range" min="1" max="6" value="4" id="variantCount" oninput="document.getElementById('variantVal').textContent=this.value">
          <div class="slider-val" id="variantVal">4</div>
        </div>
      </div>

      <div class="tab-content" id="tab-advanced">
        <div class="section-title">⚙ Advanced</div>
        <select class="select-input" id="modelSelect">
          <option>SDXL 1.0 (Stability AI)</option>
          <option>FLUX.1 (Hugging Face)</option>
          <option>Stable Diffusion 3</option>
        </select>
        <div class="slider-row">
          <div class="slider-label">CFG Scale</div>
          <input type="range" min="1" max="20" value="7" id="cfgScale" oninput="document.getElementById('cfgVal').textContent=this.value">
          <div class="slider-val" id="cfgVal">7</div>
        </div>
        <div class="slider-row">
          <div class="slider-label">Steps</div>
          <input type="range" min="20" max="50" value="30" id="steps" oninput="document.getElementById('stepsVal').textContent=this.value">
          <div class="slider-val" id="stepsVal">30</div>
        </div>
        <select class="select-input" id="ratioSelect">
          <option value="3:4">Portrait 3:4</option>
          <option value="9:16">Reel 9:16</option>
          <option value="1:1">Square 1:1</option>
          <option value="16:9">Landscape 16:9</option>
        </select>
      </div>

      <button class="btn-generate" id="generateBtn" onclick="startGeneration()">
        ✦ Generate Try-On
      </button>

    </div>

    <!-- CENTER -->
    <div class="canvas-area">
      <div class="canvas-header">
        <div class="canvas-title">Generation Canvas</div>
        <div class="canvas-actions">
          <button class="btn-sm" onclick="downloadAll()">⬇ Save All</button>
          <button class="btn-sm" onclick="clearCanvas()">🗑 Clear</button>
          <div class="progress-bar" style="width:120px;margin:0">
            <div class="progress-fill" id="progressFill"></div>
          </div>
        </div>
      </div>
      <div class="results-grid" id="resultsGrid">
        <div class="empty-state">
          <div class="empty-icon">✦</div>
          <div class="empty-title">Your canvas awaits</div>
          <div class="empty-sub">Upload a fabric image → Select model → Generate</div>
        </div>
      </div>
    </div>

    <!-- RIGHT PANEL -->
    <div class="panel">
      <div class="section-title">🔍 AI Analysis</div>
      <div class="analysis-box" id="analysisBox">
        <span style="color:var(--muted);font-style:italic">Upload fabric image to see Claude's analysis...</span>
      </div>
      <div id="fabricTags"></div>

      <div class="section-title">📝 AI Prompt</div>
      <div class="analysis-box" id="promptBox" style="min-height:80px">
        <span style="color:var(--muted);font-style:italic">Prompt will appear here after analysis...</span>
      </div>

      <div class="section-title">📋 History</div>
      <div id="historyList">
        <div style="color:var(--muted);font-size:0.82rem;text-align:center;padding:20px">No generations yet</div>
      </div>
    </div>

  </div>

  <!-- ═══ GALLERY VIEW ═══ -->
  <div class="app-body" id="view-gallery" style="display:none">
    <div style="grid-column:1/-1;padding:30px">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;margin-bottom:20px;color:var(--accent)">✦ My Gallery</h2>
      <div id="galleryGrid" class="results-grid" style="height:auto">
        <div class="empty-state"><div class="empty-icon">🖼</div><div class="empty-title">Gallery empty</div><div class="empty-sub">Generate images to see them here</div></div>
      </div>
    </div>
  </div>

  <!-- ═══ VIDEO AD VIEW ═══ -->
  <div class="app-body" id="view-videoad" style="display:none">
    <div style="grid-column:1/-1;padding:30px;max-width:800px;margin:0 auto;width:100%">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;margin-bottom:8px;color:var(--accent)">✦ Video Ad Generator</h2>
      <p style="color:var(--muted);margin-bottom:28px;font-size:0.88rem">Generate product video ad scripts & prompts using AI</p>
      <div class="upload-zone" id="videoProductZone" style="margin-bottom:20px">
        <input type="file" accept="image/*" onchange="handleVideoProduct(event)">
        <div class="upload-icon">📦</div>
        <div class="upload-text"><strong>Upload Product Image</strong>Any product — clothing, jewelry, accessories</div>
        <img id="videoProductPreview" class="preview-img">
      </div>
      <div class="input-group" style="margin-bottom:16px">
        <label style="color:var(--muted);font-size:0.8rem;display:block;margin-bottom:6px">Ad Type</label>
        <div class="tag-group">
          <div class="tag active" onclick="selectTag(this,'adtype')">Instagram Reel</div>
          <div class="tag" onclick="selectTag(this,'adtype')">YouTube Ad</div>
          <div class="tag" onclick="selectTag(this,'adtype')">WhatsApp Status</div>
          <div class="tag" onclick="selectTag(this,'adtype')">Facebook Ad</div>
        </div>
      </div>
      <textarea class="prompt-box" id="videoHint" placeholder="Hint dein — e.g. 'Navratri collection, bright colors, Surat fabric'" style="height:70px"></textarea>
      <button class="btn-generate" onclick="generateVideoScript()" style="max-width:300px">🎬 Generate Ad Script</button>
      <div id="videoScriptResult" style="margin-top:24px"></div>
    </div>
  </div>

  <!-- ═══ SETTINGS VIEW ═══ -->
  <div class="app-body" id="view-settings" style="display:none">
    <div style="grid-column:1/-1;padding:30px;max-width:600px">
      <h2 style="font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;margin-bottom:24px;color:var(--accent)">⚙ Settings</h2>
      <div style="background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:24px;margin-bottom:16px">
        <div style="font-size:1rem;color:var(--text);margin-bottom:16px">🔑 API Keys</div>
        <div class="input-group">
          <label>Anthropic Claude API Key</label>
          <input class="api-key-input" style="width:100%;padding:10px 14px;border-radius:10px;font-size:0.85rem" type="password" id="claudeKeySettings" placeholder="sk-ant-api03-...">
        </div>
        <div class="input-group" style="margin-top:12px">
          <label>Stability AI Key</label>
          <input class="api-key-input" style="width:100%;padding:10px 14px;border-radius:10px;font-size:0.85rem" type="password" id="stabilityKeySettings" placeholder="sk-...">
        </div>
        <button class="btn-generate" onclick="saveAllKeys()" style="margin-top:16px;max-width:200px">Save Keys</button>
      </div>
      <div style="background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:24px">
        <div style="font-size:1rem;color:var(--text);margin-bottom:16px">📊 Account</div>
        <div style="display:flex;justify-content:space-between;margin-bottom:12px">
          <span style="color:var(--muted);font-size:0.85rem">Plan</span>
          <span class="badge">Free — 50 Credits</span>
        </div>
        <div style="display:flex;justify-content:space-between">
          <span style="color:var(--muted);font-size:0.85rem">Credits Used</span>
          <span style="font-size:0.85rem;color:var(--accent)" id="creditsUsedDisplay">0 / 50</span>
        </div>
      </div>
    </div>
  </div>

</div><!-- /mainApp -->

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ── STATE ──
const state = {
  claudeKey: localStorage.getItem('claudeKey') || '',
  stabilityKey: localStorage.getItem('stabilityKey') || '',
  fabricImage: null,
  fabricBase64: null,
  selectedModel: 'Ananya',
  selectedOutfit: 'Ghagra',
  selectedStyle: 'Photorealistic',
  selectedPose: 'Studio',
  selectedAdType: 'Instagram Reel',
  credits: parseInt(localStorage.getItem('credits') || '50'),
  generations: JSON.parse(localStorage.getItem('generations') || '[]'),
  analysisResult: null
};

// Pre-fill saved keys
if (state.claudeKey) document.getElementById('claudeKey').value = state.claudeKey;
if (state.stabilityKey) document.getElementById('stabilityKey').value = state.stabilityKey;
updateCreditsDisplay();

// ── LOGIN ──
function doLogin() {
  document.getElementById('loginScreen').style.animation = 'fadeOut 0.4s forwards';
  setTimeout(() => {
    document.getElementById('loginScreen').style.display = 'none';
    document.getElementById('mainApp').style.display = 'block';
  }, 400);
}

const style2 = document.createElement('style');
style2.textContent = '@keyframes fadeOut{to{opacity:0;transform:scale(0.98)}}';
document.head.appendChild(style2);

// ── NAVIGATION ──
function switchView(view, btn) {
  ['tryon','gallery','videoad','settings'].forEach(v => {
    const el = document.getElementById('view-'+v);
    if(el) el.style.display = 'none';
  });
  document.getElementById('view-'+view).style.display = view === 'tryon' ? 'grid' : 'block';
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

function switchTab(btn, tab) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tab-'+tab).classList.add('active');
}

// ── TAG SELECTION ──
function selectTag(el, group) {
  const parent = el.closest('.tag-group');
  parent.querySelectorAll('.tag').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  const val = el.textContent.trim();
  if(group === 'outfit') state.selectedOutfit = val;
  if(group === 'style') state.selectedStyle = val;
  if(group === 'pose') state.selectedPose = val;
  if(group === 'adtype') state.selectedAdType = val;
}

// ── MODEL SELECT ──
function selectModel(card, name) {
  document.querySelectorAll('.model-card').forEach(c => c.classList.remove('active'));
  card.classList.add('active');
  state.selectedModel = name;
}

// ── FABRIC UPLOAD ──
function handleFabricUpload(e) {
  const file = e.target.files[0];
  if(!file) return;
  state.fabricImage = file;
  const reader = new FileReader();
  reader.onload = (ev) => {
    state.fabricBase64 = ev.target.result.split(',')[1];
    const preview = document.getElementById('fabricPreview');
    preview.src = ev.target.result;
    preview.style.display = 'block';
    document.querySelector('#fabricZone .upload-text').style.display = 'none';
    document.querySelector('#fabricZone .upload-icon').style.display = 'none';
    analyzeFabric();
  };
  reader.readAsDataURL(file);
}

// ── ANALYZE FABRIC WITH CLAUDE ──
async function analyzeFabric() {
  const box = document.getElementById('analysisBox');
  box.className = 'analysis-box loading';
  box.innerHTML = '⟳ Claude analyzing fabric...';

  const key = state.claudeKey || document.getElementById('claudeKey').value;
  if(!key) {
    box.className = 'analysis-box';
    box.innerHTML = '<span style="color:#e07070">⚠ Please add Anthropic API key first</span>';
    return;
  }

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': key,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-opus-4-5',
        max_tokens: 600,
        messages: [{
          role: 'user',
          content: [
            { type: 'image', source: { type: 'base64', media_type: 'image/jpeg', data: state.fabricBase64 } },
            { type: 'text', text: `Analyze this fabric/clothing image for a fashion AI virtual try-on system. Respond in JSON only, no markdown:
{
  "fabric_type": "silk/cotton/georgette/etc",
  "colors": ["primary color", "secondary color"],
  "pattern": "floral/geometric/plain/printed/etc",
  "print_description": "detailed description of print",
  "texture": "smooth/rough/sheer/etc",
  "occasion": "casual/bridal/festival/party/etc",
  "image_gen_prompt": "detailed Stable Diffusion prompt for a model wearing this as ${state.selectedOutfit} - include exact colors, pattern, fabric, pose: ${state.selectedPose} style, photorealistic fashion photography"
}` }
          ]
        }]
      })
    });
    const data = await res.json();
    let text = data.content[0].text.replace(/```json|```/g,'').trim();
    const analysis = JSON.parse(text);
    state.analysisResult = analysis;

    box.className = 'analysis-box';
    box.innerHTML = `
      <strong style="color:var(--accent2)">${analysis.fabric_type}</strong> — ${analysis.print_description}<br><br>
      <strong>Occasion:</strong> ${analysis.occasion}<br>
      <strong>Texture:</strong> ${analysis.texture}
    `;

    const tagsEl = document.getElementById('fabricTags');
    tagsEl.innerHTML = analysis.colors.map(c => `<span class="badge">${c}</span>`).join('') +
      `<span class="badge">${analysis.pattern}</span>`;

    document.getElementById('promptBox').innerHTML = `<small style="color:var(--accent2)">${analysis.image_gen_prompt}</small>`;
    showToast('✦ Fabric analyzed! Ready to generate.');
  } catch(err) {
    box.className = 'analysis-box';
    box.innerHTML = `<span style="color:#e07070">Error: ${err.message}</span>`;
  }
}

// ── GENERATE ──
async function startGeneration() {
  if(!state.fabricImage) { showToast('⚠ Please upload fabric image first'); return; }
  if(state.credits <= 0) { showToast('⚠ No credits left!'); return; }

  const count = parseInt(document.getElementById('variantCount').value);
  const btn = document.getElementById('generateBtn');
  btn.disabled = true;
  btn.textContent = '⟳ Generating...';

  // Clear empty state
  const grid = document.getElementById('resultsGrid');
  const empty = grid.querySelector('.empty-state');
  if(empty) empty.remove();

  // Create placeholder cards
  const cards = [];
  for(let i = 0; i < count; i++) {
    const card = document.createElement('div');
    card.className = 'result-card';
    card.style.animationDelay = (i*0.08)+'s';
    card.innerHTML = `
      <div class="result-img-placeholder">
        <div class="spin">✦</div>
        <div>Generating ${i+1}/${count}...</div>
      </div>
      <div class="result-meta">
        <div class="result-label">${state.selectedOutfit} — ${state.selectedModel}</div>
        <div class="result-sub">Processing...</div>
      </div>`;
    grid.appendChild(card);
    cards.push(card);
  }

  // Progress
  const prog = document.getElementById('progressFill');

  for(let i = 0; i < count; i++) {
    prog.style.width = ((i+1)/count*100)+'%';
    await generateOne(cards[i], i+1);
    state.credits = Math.max(0, state.credits - 1);
    updateCreditsDisplay();
    localStorage.setItem('credits', state.credits);
  }

  btn.disabled = false;
  btn.textContent = '✦ Generate Try-On';
  showToast(`✦ ${count} variants generated!`);
  addToHistory();
}

async function generateOne(card, idx) {
  const stabilityKey = state.stabilityKey || document.getElementById('stabilityKey').value;
  const prompt = state.analysisResult?.image_gen_prompt ||
    `Professional fashion photography, Indian ${state.selectedModel} model wearing beautiful ${state.selectedOutfit}, ${state.selectedPose} setting, photorealistic, high quality, 8K`;

  if(stabilityKey && stabilityKey.length > 10) {
    try {
      const formData = new FormData();
      formData.append('prompt', prompt);
      formData.append('negative_prompt', 'blurry, low quality, distorted, ugly, bad anatomy');
      formData.append('width', '512');
      formData.append('height', '768');
      formData.append('cfg_scale', document.getElementById('cfgScale')?.value || '7');
      formData.append('steps', document.getElementById('steps')?.value || '30');
      formData.append('samples', '1');

      const res = await fetch('https://api.stability.ai/v1/generation/stable-diffusion-xl-1024-v1-0/text-to-image', {
        method: 'POST',
        headers: { Authorization: `Bearer ${stabilityKey}` },
        body: formData
      });
      const data = await res.json();
      if(data.artifacts?.[0]?.base64) {
        const imgSrc = 'data:image/png;base64,' + data.artifacts[0].base64;
        card.innerHTML = `
          <img src="${imgSrc}" class="result-img" loading="lazy">
          <div class="result-meta">
            <div class="result-label">Variant ${idx} — ${state.selectedOutfit}</div>
            <div class="result-sub">${state.selectedModel} · ${state.selectedStyle}</div>
          </div>
          <div class="result-actions">
            <button class="btn-action primary" onclick="downloadImg(this,'variant-${idx}.png')">⬇ Save</button>
            <button class="btn-action" onclick="generateVariation(this)">🔄 Vary</button>
          </div>`;
        state.generations.unshift({img:imgSrc, label:`Variant ${idx}`, time: new Date().toLocaleTimeString()});
        localStorage.setItem('generations', JSON.stringify(state.generations.slice(0,20)));
        updateHistory();
        return;
      }
    } catch(e) { console.log('Stability error:', e); }
  }

  // Fallback: show prompt instead
  card.innerHTML = `
    <div class="result-img-placeholder" style="padding:20px;text-align:center;font-size:0.75rem;color:var(--muted)">
      <div style="font-size:1.5rem;margin-bottom:10px">🖼</div>
      <div style="color:var(--accent2);margin-bottom:8px">AI Prompt Ready</div>
      <div style="line-height:1.5">${(prompt||'').substring(0,120)}...</div>
    </div>
    <div class="result-meta">
      <div class="result-label">Variant ${idx} — ${state.selectedOutfit}</div>
      <div class="result-sub">Add Stability AI key for real images</div>
    </div>
    <div class="result-actions">
      <button class="btn-action" onclick="copyPrompt('${(prompt||'').replace(/'/g,'')}')">📋 Copy Prompt</button>
    </div>`;
}

// ── VIDEO AD SCRIPT ──
function handleVideoProduct(e) {
  const file = e.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = (ev) => {
    document.getElementById('videoProductPreview').src = ev.target.result;
    document.getElementById('videoProductPreview').style.display = 'block';
  };
  reader.readAsDataURL(file);
}

async function generateVideoScript() {
  const key = state.claudeKey || document.getElementById('claudeKey').value;
  const hint = document.getElementById('videoHint').value;
  const resultBox = document.getElementById('videoScriptResult');
  const adType = state.selectedAdType;

  if(!key) { showToast('⚠ Add Anthropic API key in Settings'); return; }

  resultBox.innerHTML = '<div style="color:var(--muted);font-style:italic;padding:20px">⟳ Generating ad script...</div>';

  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': key,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-opus-4-5',
        max_tokens: 800,
        messages: [{
          role: 'user',
          content: `Create a compelling ${adType} video ad script for a fashion/clothing product. Context: "${hint || 'Indian fashion clothing'}". 
          
Include:
1. Hook (first 3 seconds - attention grabbing)
2. Scene-by-scene breakdown (5-7 scenes)
3. Voice-over text (Hindi/English mix preferred for Indian audience)
4. Music suggestion
5. Call-to-action

Format it nicely with emojis. Keep it punchy and viral-worthy for Surat textile/fashion market.`
        }]
      })
    });
    const data = await res.json();
    const script = data.content[0].text;
    resultBox.innerHTML = `
      <div style="background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:24px">
        <div style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;color:var(--accent);margin-bottom:16px">✦ Your ${adType} Script</div>
        <div style="font-size:0.85rem;line-height:1.8;color:var(--text);white-space:pre-wrap">${script}</div>
        <button class="btn-action" style="margin-top:16px;padding:10px 20px" onclick="navigator.clipboard.writeText(\`${script.replace(/`/g,"'")}\`)">📋 Copy Script</button>
      </div>`;
  } catch(e) {
    resultBox.innerHTML = `<div style="color:#e07070">Error: ${e.message}</div>`;
  }
}

// ── HELPERS ──
function saveKey(type) {
  if(type === 'claude') {
    state.claudeKey = document.getElementById('claudeKey').value;
    localStorage.setItem('claudeKey', state.claudeKey);
    showToast('✦ Claude key saved!');
  } else {
    state.stabilityKey = document.getElementById('stabilityKey').value;
    localStorage.setItem('stabilityKey', state.stabilityKey);
    showToast('✦ Stability AI key saved!');
  }
}

function saveAllKeys() {
  state.claudeKey = document.getElementById('claudeKeySettings').value || state.claudeKey;
  state.stabilityKey = document.getElementById('stabilityKeySettings').value || state.stabilityKey;
  localStorage.setItem('claudeKey', state.claudeKey);
  localStorage.setItem('stabilityKey', state.stabilityKey);
  if(state.claudeKey) document.getElementById('claudeKey').value = state.claudeKey;
  if(state.stabilityKey) document.getElementById('stabilityKey').value = state.stabilityKey;
  showToast('✦ All keys saved!');
}

function updateCreditsDisplay() {
  document.getElementById('creditsDisplay').textContent = `✦ ${state.credits} Credits`;
  document.getElementById('creditsUsedDisplay').textContent = `${50-state.credits} / 50`;
}

function downloadImg(btn, name) {
  const img = btn.closest('.result-card').querySelector('img');
  if(!img) return;
  const a = document.createElement('a'); a.href = img.src; a.download = name; a.click();
}

function downloadAll() {
  document.querySelectorAll('.result-card img').forEach((img,i) => {
    setTimeout(() => {
      const a = document.createElement('a'); a.href = img.src;
      a.download = `fashionai-${i+1}.png`; a.click();
    }, i*300);
  });
}

function clearCanvas() {
  document.getElementById('resultsGrid').innerHTML = `
    <div class="empty-state">
      <div class="empty-icon">✦</div>
      <div class="empty-title">Canvas cleared</div>
      <div class="empty-sub">Upload a fabric image → Select model → Generate</div>
    </div>`;
}

function copyPrompt(text) {
  navigator.clipboard.writeText(text);
  showToast('📋 Prompt copied!');
}

function generateVariation(btn) {
  showToast('🔄 Generating variation...');
}

function addToHistory() { updateHistory(); }

function updateHistory() {
  const list = document.getElementById('historyList');
  if(!state.generations.length) return;
  list.innerHTML = state.generations.slice(0,6).map(g => `
    <div class="history-item">
      <div class="history-thumb">${g.img ? `<img src="${g.img}">` : '✦'}</div>
      <div class="history-info">
        <div class="history-prompt">${g.label}</div>
        <div class="history-time">${g.time}</div>
      </div>
    </div>`).join('');
  
  // Update gallery
  const gallery = document.getElementById('galleryGrid');
  gallery.innerHTML = state.generations.map((g,i) => g.img ? `
    <div class="result-card">
      <img src="${g.img}" class="result-img">
      <div class="result-meta"><div class="result-label">${g.label}</div><div class="result-sub">${g.time}</div></div>
      <div class="result-actions">
        <button class="btn-action primary" onclick="downloadImg(this,'gallery-${i}.png')">⬇ Save</button>
      </div>
    </div>` : '').join('') || `<div class="empty-state"><div class="empty-icon">🖼</div><div class="empty-title">Gallery empty</div></div>`;
}

function showToast(msg, dur=3000) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), dur);
}

// Load saved history
updateHistory();
</script>
</body>
</html>
